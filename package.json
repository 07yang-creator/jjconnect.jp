{
  "name": "jjconnect-auth",
  "version": "1.0.0",
  "description": "JJConnect Authentication System with Cloudflare Workers",
  "main": "workers/auth-worker.js",
  "scripts": {
    "inject-env": "node scripts/inject-env-into-html.js",
    "generate:public-config": "node scripts/generate-public-config-js.mjs",
    "sync:static-root": "node scripts/sync-static-to-github-pages-root.mjs",
    "prepare:pages-static": "npm run generate:public-config && npm run inject-env && npm run sync:static-root",
    "dev": "next dev",
    "predev": "node scripts/copy-wordpress-into-public.mjs && node scripts/generate-public-config-js.mjs",
    "build": "node scripts/copy-wordpress-into-public.mjs && node scripts/generate-public-config-js.mjs && node scripts/sync-static-to-github-pages-root.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "build:worker": "echo 'Build step - copying worker files' && mkdir -p .wrangler/dist && cp workers/auth-worker.js .wrangler/dist/index.js",
    "sync-admin": "cp admin.html public/admin.html",
    "dev:worker": "cd workers && wrangler dev",
    "deploy": "cd workers && wrangler deploy",
    "deploy:production": "cd workers && wrangler deploy",
    "deploy:development": "cd workers && wrangler deploy --env development",
    "tail": "cd workers && wrangler tail",
    "tail:dev": "cd workers && wrangler tail --env development",
    "login": "cd workers && wrangler login",
    "logout": "cd workers && wrangler logout",
    "whoami": "cd workers && wrangler whoami",
    "verify:auth": "node scripts/verify-auth-diagnostics.mjs",
    "audit:test-users": "node scripts/audit-supabase-test-users.mjs",
    "cleanup:vv-test-users": "node scripts/delete-vv-test-users.mjs",
    "seed:vv-test-users": "node scripts/seed-vv-test-users.mjs",
    "grant:full-access": "node scripts/grant-full-access-by-email.mjs",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:manual": "playwright test e2e/manual-email-approval.spec.ts --headed",
    "e2e:install": "playwright install chromium",
    "e2e:report": "playwright show-report"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "authentication",
    "jwt"
  ],
  "author": "JJConnect",
  "license": "MIT",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "wrangler": "^3.0.0"
  },
  "dependencies": {
    "@auth0/nextjs-auth0": "^4.16.0",
    "@floating-ui/dom": "^1.7.6",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.95.3",
    "@tiptap/extension-file-handler": "^3.20.0",
    "@tiptap/extension-font-family": "^3.22.2",
    "@tiptap/extension-highlight": "^3.22.2",
    "@tiptap/extension-horizontal-rule": "^3.22.2",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/extension-task-item": "^3.22.2",
    "@tiptap/extension-task-list": "^3.22.2",
    "@tiptap/extension-text-align": "^3.22.2",
    "@tiptap/extension-text-style": "^3.22.2",
    "@tiptap/extension-underline": "^3.22.2",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@tiptap/suggestion": "^3.20.0",
    "next": "^15.5.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^4.8.0",
    "sanitize-html": "^2.17.1",
    "zod": "^3.23.0"
  }
}

{
  "name": "jjconnect-auth",
  "version": "1.0.0",
  "description": "JJConnect Authentication System with Cloudflare Workers",
  "main": "workers/auth-worker.js",
  "scripts": {
    "inject-env": "node scripts/inject-env-into-html.js",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "build:worker": "echo 'Build step - copying worker files' && mkdir -p .wrangler/dist && cp workers/auth-worker.js .wrangler/dist/index.js",
    "dev:worker": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:production": "wrangler deploy --env production",
    "deploy:development": "wrangler deploy --env development",
    "tail": "wrangler tail",
    "login": "wrangler login",
    "logout": "wrangler logout",
    "whoami": "wrangler whoami"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "authentication",
    "jwt"
  ],
  "author": "JJConnect",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "wrangler": "^3.0.0"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.95.3",
    "@tiptap/extension-file-handler": "^3.20.0",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@tiptap/suggestion": "^3.20.0",
    "@floating-ui/dom": "^1.6.0",
    "next": "^14.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "zod": "^3.23.0"
  }
}

# =============================================================================
# JJConnect Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# Do NOT commit .env to git - it contains secrets.
# =============================================================================

# Supabase (required for Next.js app and static publish page)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase (alternate names - used by workers, GitHub Actions)
# Add these to wrangler secrets / GitHub Secrets
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# App URL (used in emails, links)
NEXT_PUBLIC_APP_URL=https://jjconnect.jp

# Auth provider mode: supabase (default) or auth0 (keep both in sync; JJC_* wins when set explicitly)
JJC_AUTH_PROVIDER=supabase
NEXT_PUBLIC_AUTH_PROVIDER=supabase

# Auth0 (required when JJC_AUTH_PROVIDER=auth0)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
AUTH0_SECRET=replace_with_long_random_secret
APP_BASE_URL=https://jjconnect.jp

# Auth0 connection names (must match Auth0 Dashboard → Authentication → Social / Enterprise).
# Defaults work for standard social connections; override if your tenant uses different names.
# Server-only (recommended): used by /api/public-config for static login.html
# AUTH0_CONNECTION_GOOGLE=google-oauth2
# AUTH0_CONNECTION_FACEBOOK=facebook
# AUTH0_CONNECTION_LINE=line
# AUTH0_CONNECTION_YAHOO=yahoo
# Optional browser override for Next.js /login (same values as above if you set them here):
# NEXT_PUBLIC_AUTH0_CONNECTION_GOOGLE=google-oauth2

# Diagnostics: GET /api/auth/diagnostics — production requires header x-auth-diagnostics: <secret>
# AUTH_DIAGNOSTICS_SECRET=your_random_secret

# reCAPTCHA v3 (used in static HTML: index.html, feedback.html, about.html)
# Get keys from https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
# Optional: placeholder string in HTML to replace (default: __RECAPTCHA_SITE_KEY__)
# RECAPTCHA_PLACEHOLDER=__RECAPTCHA_SITE_KEY__

# Email (optional - used by lib/email.ts)
REVIEW_ADMIN_EMAIL=review@jjconnect.jp
FROM_EMAIL=noreply@jjconnect.jp
FROM_NAME=JJConnect

# Cloudflare Workers (use .dev.vars for local, wrangler secret for production)
# JWT_SECRET - set via: npx wrangler secret put JWT_SECRET

# Supabase service role (required for Auth0 incremental mapping flow)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Role Matrix - Google Sheet CSV export URL (for admin "更新授权" sync)
# ROLE_MATRIX_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv&gid=0

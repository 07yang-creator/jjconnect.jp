# =============================================================================
# JJConnect - 开发环境 (Development)
# =============================================================================
# 复制为 .env.development 并填入真实值：
#   cp .env.development.example .env.development
# .env.development 已在 .gitignore，不会提交
# =============================================================================

# Supabase（Next.js 与静态页开发）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase 备用名（Worker / 脚本可能使用）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# 应用 URL（开发时可为 localhost）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# reCAPTCHA v3（可选，开发可先用测试 key）
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# Email（可选）
REVIEW_ADMIN_EMAIL=review@jjconnect.jp
FROM_EMAIL=noreply@jjconnect.jp
FROM_NAME=JJConnect

# Worker 内部邮件代理（方案 A：通过 CF Worker 发送邮件）
# Next.js 将邮件请求转发到 Worker，Worker 使用 MailChannels 发送
# WORKER_BASE_URL 生产时填 https://jjconnect.jp，本地开发填 Worker 的 wrangler dev URL
WORKER_BASE_URL=https://jjconnect.jp
# INTERNAL_API_SECRET 须与 CF Worker 的同名 secret 一致（wrangler secret put INTERNAL_API_SECRET）
INTERNAL_API_SECRET=your_random_secret_here

# =============================================================================
# JJConnect - 开发环境 (Development)
# =============================================================================
# 复制为 .env.development 并填入真实值：
#   cp .env.development.example .env.development
# .env.development 已在 .gitignore，不会提交
# =============================================================================

# Supabase（Next.js 与静态页开发）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase 备用名（Worker / 脚本可能使用）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# 应用 URL（开发时可为 localhost）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 认证提供方（默认 supabase；切换到 auth0 可使用 Apple/LINE/Yahoo 等）
# Keep both in sync; JJC_* wins when set explicitly (see lib/auth/provider.ts)
JJC_AUTH_PROVIDER=supabase
NEXT_PUBLIC_AUTH_PROVIDER=supabase

# Auth0（仅在 JJC_AUTH_PROVIDER=auth0 时必填）
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
AUTH0_SECRET=replace_with_long_random_secret
APP_BASE_URL=http://localhost:3000

# Auth0 各社交连接名称（与 Dashboard 中 Connection 名称一致；默认一般可用）
# AUTH0_CONNECTION_LINE=line
# AUTH0_CONNECTION_YAHOO=yahoo
# 生产环境诊断：curl -H "x-auth-diagnostics: $SECRET" https://your-domain/api/auth/diagnostics
# AUTH_DIAGNOSTICS_SECRET=your_random_secret

# reCAPTCHA v3（可选，开发可先用测试 key）
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# Email（可选）
REVIEW_ADMIN_EMAIL=review@jjconnect.jp
FROM_EMAIL=noreply@jjconnect.jp
FROM_NAME=JJConnect

# Worker 内部邮件代理（方案 A：通过 CF Worker 发送邮件）
# Next.js 将邮件请求转发到 Worker，Worker 使用 MailChannels 发送
# WORKER_BASE_URL — production public site: https://www.jjconnect.jp; local: wrangler dev URL
WORKER_BASE_URL=https://www.jjconnect.jp
# INTERNAL_API_SECRET 须与 CF Worker 的同名 secret 一致（wrangler secret put INTERNAL_API_SECRET）
INTERNAL_API_SECRET=your_random_secret_here

# Supabase service role（Auth0 增量迁移必需）
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Cloudflare Workers local development secrets
# Copy to .dev.vars and fill in values (already in .gitignore)
# These are NOT used in production - use wrangler secret put for production

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
# 同步 role_permissions 到 Supabase 时使用（admin 更新授权双写）
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# JWT secret for auth（本地开发必填，否则会使用不安全的默认值）
JWT_SECRET=your_jwt_secret_change_in_local

# Role Matrix - Google Sheet CSV export URL (for admin "更新授权" sync)
# ROLE_MATRIX_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv&gid=0
